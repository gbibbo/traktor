#!/bin/bash
#SBATCH --job-name=v4_smoke_test_gpu
#SBATCH --partition=a100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32G
#SBATCH --time=00:30:00
#SBATCH --output=/mnt/fast/nobackup/users/gb0048/traktor/logs/%x_%j.out
#SBATCH --error=/mnt/fast/nobackup/users/gb0048/traktor/logs/%x_%j.err

# =============================================================================
# TRAKTOR ML V4 — GPU Smoke Test: 3 tracks (Apptainer edition)
# Valida que el pipeline GPU funciona antes del run completo.
# Verifica: shapes (3,1024), valores finitos, mert_perc != mert_full.
#
# Requisito: SIF descargado en scratch4weeks/apptainer/pytorch_2.5.1_cu124.sif
# (ver slurm/jobs/diag_net_pull.job para descargarlo si no está)
#
# Usage:
#   ./slurm/tools/on_submit.sh sbatch slurm/jobs/v4/smoke_test_gpu.job <dataset-name>
#
# Example:
#   ./slurm/tools/on_submit.sh sbatch slurm/jobs/v4/smoke_test_gpu.job test_20
# =============================================================================

set -euo pipefail

REPO="/mnt/fast/nobackup/users/gb0048/traktor"
SIF="/mnt/fast/nobackup/scratch4weeks/$USER/apptainer/pytorch_2.5.1_cu124.sif"

if [ "$#" -ne 1 ]; then
    echo "[ERROR] Missing dataset name."
    exit 1
fi
DATASET_NAME="$1"

echo "[INFO] ========================================================================"
echo "[INFO] TRAKTOR ML V4 — GPU Smoke Test (3 tracks)"
echo "[INFO] ========================================================================"
echo "[INFO] Dataset: $DATASET_NAME | $(date)"
echo "[INFO] SIF: $SIF"
nvidia-smi --query-gpu=name,memory.total --format=csv || echo "No GPU"

if [ ! -f "$SIF" ]; then
    echo "[ERROR] SIF not found: $SIF"
    echo "[ERROR] Run slurm/jobs/diag_net_pull.job first to download the container."
    exit 1
fi

cd "$REPO"
mkdir -p logs

# === Scratch dirs ===
SCR="/mnt/fast/nobackup/scratch4weeks/$USER"
mkdir -p "$SCR"/{python_userbase_sif,tmp,cache/pip,cache/huggingface,cache/torch,cache/xdg}

# === Env vars (heredados por apptainer exec) ===
# PYTHONUSERBASE separado para el SIF (no mezclar con el antiguo .local)
export PYTHONUSERBASE="$SCR/python_userbase_sif"
export PATH="$SCR/python_userbase_sif/bin:$PATH"
export PIP_CACHE_DIR="$SCR/cache/pip"
export HF_HOME="$SCR/cache/huggingface"
export TRANSFORMERS_CACHE="$HF_HOME"
export HF_DATASETS_CACHE="$HF_HOME"
export TORCH_HOME="$SCR/cache/torch"
export XDG_CACHE_HOME="$SCR/cache/xdg"
export TMPDIR="$SCR/tmp"
export PYTORCH_ALLOC_CONF="expandable_segments:True"
export TRAKTOR_HF_CACHE="$HF_HOME"
export TRAKTOR_TORCH_CACHE="$TORCH_HOME"
export PYTHONPATH="$REPO:${PYTHONPATH:-}"

# Alias de ejecución (--nv pasa drivers NVIDIA; bind auto por sysadmin)
APRUN="apptainer exec --nv $SIF"

# === Verificar Python + GPU ===
echo "[DIAG] $(hostname)"
$APRUN python -c "
import sys, torch
print(f'Python: {sys.version.split()[0]}')
print(f'PyTorch: {torch.__version__}')
print(f'CUDA: {torch.cuda.is_available()}, GPU: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else \"N/A\"}')"

# === Instalar dependencias extras (no incluidas en el SIF base) ===
echo "[SETUP] Installing extra dependencies..."
# Pin transformers<4.49 para compatibilidad con PyTorch 2.5.x (CVE-2025-32434 check added in >=4.49)
$APRUN pip install --user --quiet "transformers==4.44.2" pandas pyarrow soundfile tqdm demucs essentia

# === Verificar imports ===
$APRUN python -c "
import transformers, soundfile, essentia, demucs
print('[OK] transformers, soundfile, essentia, demucs importan correctamente')
"

# === Pre-download models ===
echo "[SETUP] Pre-downloading MERT + Demucs models..."
$APRUN python -c "
from transformers import AutoModel, Wav2Vec2FeatureExtractor
Wav2Vec2FeatureExtractor.from_pretrained('m-a-p/MERT-v1-330M', trust_remote_code=True)
AutoModel.from_pretrained('m-a-p/MERT-v1-330M', trust_remote_code=True)
from demucs.pretrained import get_model; get_model('htdemucs')
print('[OK] Models pre-downloaded')
"

# === Run Phase 1 — 3 tracks only ===
echo "[RUN] Extracting 3 tracks (smoke test)..."
$APRUN python "$REPO/src/v4/pipeline/phase1_extract.py" \
    --dataset-name "$DATASET_NAME" \
    --device cuda \
    --shard-id 0 \
    --num-shards 1 \
    --checkpoint-every 1 \
    --max-tracks 3

EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    echo "[VALIDATE] Checking smoke test output..."
    $APRUN python -c "
import numpy as np, json, sys
from pathlib import Path

repo = Path('$REPO')
artifacts = repo / 'artifacts/v4/datasets/$DATASET_NAME'
shards = artifacts / 'embeddings/shards'

perc = np.load(shards / 'mert_perc_shard_00.npy')
full = np.load(shards / 'mert_full_shard_00.npy')
with open(shards / 'track_uids_shard_00.json') as f:
    uids = json.load(f)

print(f'  mert_perc shape: {perc.shape}')
print(f'  mert_full shape: {full.shape}')

assert perc.shape == (3, 1024), f'Expected (3,1024), got {perc.shape}'
assert full.shape == (3, 1024), f'Expected (3,1024), got {full.shape}'
assert np.isfinite(perc).all(), 'mert_perc has non-finite values!'
assert np.isfinite(full).all(), 'mert_full has non-finite values!'
assert len(uids) == 3, f'Expected 3 UIDs, got {len(uids)}'

from numpy.linalg import norm
cos_dists = []
for i in range(len(uids)):
    p, f = perc[i], full[i]
    cos = 1 - np.dot(p, f) / (norm(p) * norm(f))
    cos_dists.append(cos)
mean_cos = float(np.mean(cos_dists))
print(f'  Mean cosine distance (perc vs full): {mean_cos:.4f}')
assert mean_cos > 0.05, f'mert_perc and mert_full are too similar (cos_dist={mean_cos:.4f}).'

print('[OK] SMOKE TEST PASSED: shapes, finite values, perc!=full verified')
"
    VALIDATE_CODE=$?
else
    echo "[ERROR] Phase 1 failed, skipping validation."
    VALIDATE_CODE=1
fi

echo "[INFO] ========================================================================"
if [ $VALIDATE_CODE -eq 0 ]; then
    echo "[INFO] SMOKE TEST COMPLETE — ALL CHECKS PASSED"
    echo "[INFO] Ready to submit full Phase 1 extraction."
else
    echo "[ERROR] SMOKE TEST FAILED — check logs before full run"
fi
echo "[INFO] End time: $(date)"
echo "[INFO] ========================================================================"

exit $VALIDATE_CODE
